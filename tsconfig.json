{
  "compilerOptions": {
    "target": "ES2019",
    "module": "esnext",
    "lib": ["ES2019", "DOM"],
    "jsx": "react",
    "moduleResolution": "node",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["src"]
}
